APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
TZ=Asia/Krasnoyarsk

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/job_matcher
ASYNC_DATABASE_URL=postgresql+psycopg_async://postgres:postgres@localhost:5432/job_matcher
REDIS_URL=redis://localhost:6379/0

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ENABLED=false
TELEGRAM_SOURCE_ENABLED=false
TELEGRAM_SOURCE_CHANNELS=
TELEGRAM_TDLIB_API_ID=
TELEGRAM_TDLIB_API_HASH=
TELEGRAM_TDLIB_PHONE_NUMBER=
TELEGRAM_TDLIB_AUTH_CODE=
TELEGRAM_TDLIB_PASSWORD=
TELEGRAM_TDLIB_DB_DIR=./.tdlib
TELEGRAM_TDLIB_FILES_DIR=./.tdlib-files
TELEGRAM_TDLIB_ENCRYPTION_KEY=
TELEGRAM_TDJSON_LIB_PATH=

COLLECT_INTERVAL_MINUTES=20
MATCH_SCORE_THRESHOLD=70
ENABLE_SCHEDULER=true
ENABLE_DEMO_MODE=true
ENABLE_EXPERIMENTAL_ADAPTERS=false

HH_API_BASE_URL=https://api.hh.ru
SUPERJOB_API_KEY=
REQUEST_TIMEOUT_SECONDS=20
REQUEST_RETRIES=3
REQUEST_BACKOFF_SECONDS=1
HTTP_USER_AGENT=ai-job-aggregator/0.1 (+local-mvp)

SCORING_RULES_PATH=./config/scoring_rules.yaml
MCP_HOST=0.0.0.0
MCP_PORT=8001
